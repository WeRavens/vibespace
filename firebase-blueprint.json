{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "createdAt"]
    },
    "Vibe": {
      "title": "Vibe",
      "description": "A real-time post from a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["photo", "video", "text"] },
        "mood": { "type": "string", "enum": ["happy", "sad", "excited", "chill", "angry", "thinking"] },
        "isAnonymous": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "reactions": { "type": "object" }
      },
      "required": ["userId", "type", "mood", "createdAt", "expiresAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/vibes/{vibeId}": {
      "schema": "Vibe",
      "description": "Public vibes feed"
    }
  }
}
