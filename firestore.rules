rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasAdminOverride() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.overrideAdmin == true;
    }

    function hasAdminEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*(ikfah|admin).*');
    }

    function isAdmin() {
      return hasAdminOverride() || hasAdminEmail();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // Data Invariants
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt'])
        && data.uid is string
        && (data.displayName == null || data.displayName is string)
        && (data.photoURL == null || data.photoURL is string)
        && (data.bio == null || data.bio is string)
        && data.createdAt == request.time;
    }

    function isValidVibe(data) {
      return data.keys().hasAll(['userId', 'type', 'mood', 'createdAt', 'expiresAt'])
        && data.userId == request.auth.uid
        && data.type in ['photo', 'video', 'text']
        && data.mood in ['happy', 'sad', 'excited', 'chill', 'angry', 'thinking']
        && data.createdAt == request.time
        && data.expiresAt is timestamp
        && (data.content == null || (data.content is string && data.content.size() <= 5000))
        && (data.isAnonymous is bool)
        && (data.reactions is map);
    }

    // -------------------------------------------------------------------------
    // Default Deny
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // User Profiles
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (
          isOwner(userId) 
          && incoming().uid == existing().uid
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio'])
        )
        || (
          isAdmin()
          && incoming().uid == existing().uid
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['isBanned', 'bannedAt', 'unbannedAt'])
        );
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Vibes (Posts)
    // -------------------------------------------------------------------------
    match /vibes/{vibeId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(vibeId) && isValidVibe(incoming());
      
      allow update: if isSignedIn() && (
        // Action: React
        (incoming().diff(existing()).affectedKeys().hasOnly(['reactions']) && isValidVibe(incoming()))
        // Action: Edit (only owner)
        || (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mood', 'isAnonymous']))
      );
      
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /bannedUsers/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
      allow update: if false;
    }
  }
}
